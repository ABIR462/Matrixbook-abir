# MATRIXBOOK CORE - Neural Operating System Configuration

# Obtain from https://aistudio.google.com/app/apikey
# If using the AI Studio Secret panel, set GEMINI_API_KEY
VITE_GEMINI_API_KEY=

# Obtain from https://console.mistral.ai/
VITE_MISTRAL_API_KEY=
VITE_MISTRAL_MODEL=codestral-latest
VITE_MISTRAL_CHAT_ENDPOINT=https://api.mistral.ai/v1/chat/completions

# Obtain from Firebase Console -> Project Settings
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Production sync
VITE_APP_URL=http://localhost:3000
