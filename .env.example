# MATRIXBOOK CORE - Neural Operating System Configuration

# Obtain from https://aistudio.google.com/app/apikey
# If using the AI Studio Secret panel, set GEMINI_API_KEY
VITE_GEMINI_API_KEY=

# Obtain from https://openrouter.ai/
VITE_OPENROUTER_API_KEY=
VITE_OPENROUTER_MODEL=inclusionai/ling-2.6-1t:free

# Obtain from https://ably.com/
VITE_ABLY_API_KEY=

# Obtain from Firebase Console -> Project Settings
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Production sync
VITE_APP_URL=http://localhost:3000
